#!/bin/bash
set -euo pipefail

# Aero Linux - Theme Manager
# Applies theme configurations across Hyprland, Waybar, Ghostty, etc.

AERO_THEMES="/usr/share/aero/themes"
AERO_CONFIGS="/usr/share/aero/configs"
CURRENT_THEME_FILE="${XDG_CONFIG_HOME:-$HOME/.config}/aero/current-theme"

info()  { printf "\033[1;34m[INFO]\033[0m  %s\n" "$*"; }
warn()  { printf "\033[1;33m[WARN]\033[0m  %s\n" "$*"; }
error() { printf "\033[1;31m[ERROR]\033[0m %s\n" "$*"; exit 1; }

usage() {
    cat <<EOF
Usage: aero-theme <command> [theme]

Commands:
  list              List available themes
  apply <theme>     Apply a theme
  current           Show current theme
  help              Show this help
EOF
    exit 0
}

list_themes() {
    local themes=()
    for d in "$AERO_THEMES"/*/; do
        themes+=("$(basename "$d")")
    done
    if [[ ${#themes[@]} -eq 0 ]]; then
        info "No themes found in $AERO_THEMES"
        return
    fi
    printf "Available themes:\n"
    for t in "${themes[@]}"; do
        if [[ -f "$AERO_THEMES/$t/wallpaper.jpg" ]]; then
            printf "  \033[1;36m%s\033[0m\n" "$t"
        else
            printf "  \033[2m%s\033[0m (incomplete)\n" "$t"
        fi
    done
}

apply_theme() {
    local theme="$1"
    local theme_dir="$AERO_THEMES/$theme"

    [[ -d "$theme_dir" ]] || error "Theme '$theme' not found in $AERO_THEMES"
    [[ -f "$theme_dir/wallpaper.jpg" ]] || warn "Theme '$theme' has no wallpaper"

    info "Applying theme: $theme"

    local config_dir="${XDG_CONFIG_HOME:-$HOME/.config}"

    # Hyprland appearance override
    if [[ -f "$theme_dir/hyprland.conf" ]]; then
        local hypr_dir="$config_dir/hypr"
        mkdir -p "$hypr_dir"
        cp "$theme_dir/hyprland.conf" "$hypr_dir/theme.conf"
        info "  Hyprland: applied"
    fi

    # Waybar style override
    if [[ -f "$theme_dir/waybar.css" ]]; then
        local waybar_dir="$config_dir/waybar"
        mkdir -p "$waybar_dir"
        cp "$theme_dir/waybar.css" "$waybar_dir/theme.css"
        if grep -q '@import "theme.css"' "$waybar_dir/style.css" 2>/dev/null; then
            :
        else
            printf '\n@import "theme.css";\n' >> "$waybar_dir/style.css"
        fi
        info "  Waybar: applied"
    fi

    # Ghostty color override
    if [[ -f "$theme_dir/ghostty.conf" ]]; then
        local ghostty_dir="$config_dir/ghostty"
        mkdir -p "$ghostty_dir"
        cp "$theme_dir/ghostty.conf" "$ghostty_dir/theme.conf"
        if ! grep -q 'theme.conf' "$ghostty_dir/config" 2>/dev/null; then
            printf '\nimport = theme.conf\n' >> "$ghostty_dir/config"
        fi
        info "  Ghostty: applied"
    fi

    # Mako style override
    if [[ -f "$theme_dir/mako.conf" ]]; then
        local mako_dir="$config_dir/mako"
        mkdir -p "$mako_dir"
        cp "$theme_dir/mako.conf" "$mako_dir/config"
        info "  Mako: applied"
    fi

    # Walker theme
    if [[ -f "$theme_dir/walker.css" ]]; then
        local walker_theme_dir="$config_dir/walker/themes/$theme"
        mkdir -p "$walker_theme_dir"
        cp "$theme_dir/walker.css" "$walker_theme_dir/style.css"

        # Update walker config to use this theme
        local walker_config="$config_dir/walker/config.toml"
        if [[ -f "$walker_config" ]]; then
            sed -i "s/^theme = .*/theme = \"$theme\"/" "$walker_config"
            sed -i "s|^additional_theme_location = .*|additional_theme_location = \"$config_dir/walker/themes/\"|" "$walker_config"
        fi
        info "  Walker: applied"
    fi

    # Starship prompt override
    if [[ -f "$theme_dir/starship.toml" ]]; then
        local starship_dir="${XDG_CONFIG_HOME:-$HOME/.config}"
        mkdir -p "$starship_dir"
        cp "$theme_dir/starship.toml" "$starship_dir/starship.toml"
        info "  Starship: applied"
    fi

    # Wallpaper
    if [[ -f "$theme_dir/wallpaper.jpg" ]]; then
        local aero_dir="$config_dir/aero"
        mkdir -p "$aero_dir"
        cp "$theme_dir/wallpaper.jpg" "$aero_dir/wallpaper"
        if command -v swaybg &>/dev/null; then
            swaybg -i "$aero_dir/wallpaper" -m fill &>/dev/null &
        fi
        if command -v hyprctl &>/dev/null; then
            hyprctl hyprpaper wallpaper ",$aero_dir/wallpaper" 2>/dev/null || true
        fi
        info "  Wallpaper: applied"
    fi

    # Save current theme
    mkdir -p "$(dirname "$CURRENT_THEME_FILE")"
    echo "$theme" > "$CURRENT_THEME_FILE"

    # Reload affected applications
    if command -v hyprctl &>/dev/null; then
        hyprctl reload 2>/dev/null || true
    fi
    if command -v systemctl &>/dev/null && systemctl --user is-active waybar &>/dev/null; then
        systemctl --user restart waybar 2>/dev/null || true
    fi
    if command -v makoctl &>/dev/null; then
        makoctl reload 2>/dev/null || true
    fi

    info "Theme '$theme' applied successfully"
}

show_current() {
    if [[ -f "$CURRENT_THEME_FILE" ]]; then
        printf "Current theme: \033[1;36m%s\033[0m\n" "$(cat "$CURRENT_THEME_FILE")"
    else
        info "No theme has been applied yet"
    fi
}

[[ $# -lt 1 ]] && usage
CMD="$1"
shift

case "$CMD" in
    list)
        list_themes
        ;;
    apply)
        [[ $# -lt 1 ]] && error "Usage: aero-theme apply <theme>"
        apply_theme "$1"
        ;;
    current)
        show_current
        ;;
    help|--help|-h)
        usage
        ;;
    *)
        error "Unknown command: $CMD. Use 'aero-theme help' for usage."
        ;;
esac
