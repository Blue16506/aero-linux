#!/bin/bash
set -euo pipefail

# Aero Linux Installer
# Interactive TUI-based Aero Linux installer with Hyprland desktop

INSTALL_LOG="/var/log/aero-install.log"
AERO_CONFIGS="/usr/share/aero/configs"
AERO_SCRIPTS="/usr/share/aero/scripts"

# ---------------------------------------------------------------------------
#  Utility functions
# ---------------------------------------------------------------------------

info()  { printf "\033[1;34m[INFO]\033[0m  %s\n" "$*"; }
warn()  { printf "\033[1;33m[WARN]\033[0m  %s\n" "$*"; }
error() { printf "\033[1;31m[ERROR]\033[0m %s\n" "$*"; exit 1; }
ok()    { printf "\033[1;32m  OK\033[0m\n"; }

confirm() {
    printf "\033[1;33m ? \033[0m%s [Y/n] " "$*"
    read -r r
    [[ -z "$r" || "$r" =~ ^[Yy] ]]
}

select_opt() {
    local prompt="$1" ; shift
    local opts=("$@")
    local sel=0
    while true; do
        for i in "${!opts[@]}"; do
            if [[ $i -eq $sel ]]; then
                printf " \033[1;32m>\033[0m %s\n" "${opts[$i]}" >/dev/tty
            else
                printf "   %s\n" "${opts[$i]}" >/dev/tty
            fi
        done
        read -rsn1 k
        [[ $k == $'\x1b' ]] && read -rsn2 k
        case "$k" in
            '[A'|k) ((sel > 0)) && ((--sel)) ;;
            '[B'|j) ((sel < ${#opts[@]}-1)) && ((++sel)) ;;
            $'\n'|$'\r'|"")   break ;;
        esac
        printf "\033[%dA" "${#opts[@]}" >/dev/tty
    done
    printf "\033[%dB" "${#opts[@]}" >/dev/tty
    echo "$sel"
}

select_timezone() {
    local tz_list tz filtered selected c rest
    mapfile -t tz_list < <(timedatectl list-timezones 2>/dev/null || find /usr/share/zoneinfo -type f ! -path "*/posix/*" ! -path "*/right/*" ! -path "*/Etc/*" ! -name "*.tab" ! -name "*.list" | sed 's|/usr/share/zoneinfo/||' | sort)
    [[ ${#tz_list[@]} -eq 0 ]] && tz_list=("UTC")
    selected=0
    filtered=("${tz_list[@]}")
    search_mode=false
    search_query=""

    while true; do
        printf "\033[H\033[J" >/dev/tty
        printf "\033[1;36m── Timezone selector ──────────────────────────────\033[0m\n" >/dev/tty
        if $search_mode; then
            printf "  Search: \033[1;33m%s\033[0m█\n" "$search_query" >/dev/tty
        else
            printf "  Type \033[1;33m/\033[0m to search, arrows to navigate, Enter to confirm\n" >/dev/tty
        fi
        printf "  \033[2m(%d timezones)\033[0m\n" "${#filtered[@]}" >/dev/tty

        local display_count=${#filtered[@]}
        [[ $display_count -gt 20 ]] && display_count=20
        local start=0
        [[ $selected -ge 10 ]] && start=$((selected - 10))
        local end=$((start + display_count))
        [[ $end -gt ${#filtered[@]} ]] && end=${#filtered[@]}

        for ((i = start; i < end; i++)); do
            if [[ $i -eq $selected ]]; then
                printf " \033[1;32m>\033[0m %s\n" "${filtered[$i]}" >/dev/tty
            else
                printf "   %s\n" "${filtered[$i]}" >/dev/tty
            fi
        done

        read -rsn1 k
        if [[ "$k" == "/" ]] && ! $search_mode; then
            search_mode=true
            search_query=""
            filtered=("${tz_list[@]}")
            selected=0
            continue
        fi

        if [[ "$k" == $'\x1b' ]]; then
            read -rsn2 rest 2>/dev/null || true
            if [[ "$rest" == "[A" ]]; then
                [[ $selected -gt 0 ]] && ((selected--))
            elif [[ "$rest" == "[B" ]]; then
                [[ $selected -lt $((${#filtered[@]} - 1)) ]] && ((selected++))
            elif $search_mode; then
                search_mode=false
                filtered=("${tz_list[@]}")
                selected=0
            fi
            continue
        fi

        if [[ -z "$k" || "$k" == $'\n' ]]; then
            if $search_mode; then
                search_mode=false
            fi
            echo "${filtered[$selected]}"
            return 0
        fi

        if $search_mode; then
            if [[ "$k" == $'\x7f' || "$k" == $'\b' ]]; then
                search_query="${search_query%?}"
            else
                search_query="$search_query$k"
            fi
            if [[ -z "$search_query" ]]; then
                filtered=("${tz_list[@]}")
            else
                filtered=()
                for tz in "${tz_list[@]}"; do
                    if echo "$tz" | grep -qi "$search_query"; then
                        filtered+=("$tz")
                    fi
                done
            fi
            selected=0
        fi
    done
}

# Convert disk device to partition path
# /dev/sda       -> /dev/sda1, /dev/sda2
# /dev/nvme0n1   -> /dev/nvme0n1p1, /dev/nvme0n1p2
# /dev/mmcblk0   -> /dev/mmcblk0p1, /dev/mmcblk0p2
# /dev/vda       -> /dev/vda1, /dev/vda2
get_partition() {
    local disk="$1" num="$2"
    case "$disk" in
        *nvme*|*mmcblk*|*loop*) echo "${disk}p${num}" ;;
        *)                      echo "${disk}${num}" ;;
    esac
}

cleanup() {
    [[ -d /mnt ]] && umount -R /mnt 2>/dev/null || true
}
trap cleanup EXIT

# ---------------------------------------------------------------------------
#  Phase 0 – Preflight
# ---------------------------------------------------------------------------

clear
printf "\033[1;36m"
printf "    █████╗ ███████╗██████╗  ██████╗ \n"
printf "   ██╔══██╗██╔════╝██╔══██╗██╔═══██╗\n"
printf "   ███████║█████╗  ██████╔╝██║   ██║\n"
printf "   ██╔══██║██╔══╝  ██╔══██╗██║   ██║\n"
printf "   ██║  ██║███████╗██║  ██║╚██████╔╝\n"
printf "   ╚═╝  ╚═╝╚══════╝╚═╝  ╚═╝ ╚═════╝ \n"
printf "\033[0m\n"
printf "  Aero Linux Installer\n"
printf "  %s\n\n" "$(date)"

info "Running preflight checks..."

[[ $EUID -eq 0 ]] || error "Installer must be run as root"
exec 2>"$INSTALL_LOG"

if [[ -d /sys/firmware/efi/efivars ]]; then
    UEFI=true
    info "Boot mode: UEFI"
else
    UEFI=false
    info "Boot mode: BIOS"
fi

ping -c 1 archlinux.org &>/dev/null || warn "No network detected – packages will not be downloaded"

# ---------------------------------------------------------------------------
#  Phase 1 – Interactive prompts
# ---------------------------------------------------------------------------

info "Detecting keyboard layout..."
LOCALE="en_US.UTF-8"

info "Selecting timezone..."
TIMEZONE=$(select_timezone)
info "Timezone: $TIMEZONE"

if confirm "Detect keyboard layout automatically?"; then
    KEYMAP=$(localectl status 2>/dev/null | grep "X11 Layout" | awk '{print $3}')
    : "${KEYMAP:=us}"
else
    printf "Enter keyboard layout (e.g. us, de, fr): "
    read -r KEYMAP
    : "${KEYMAP:=us}"
fi
info "Keyboard layout: $KEYMAP"

printf "\n"

AVAILABLE_DISKS=()
while IFS= read -r d; do
    [[ -b "$d" && ! "$d" =~ loop && ! "$d" =~ sr ]] && AVAILABLE_DISKS+=("$d ($(lsblk -ndo SIZE "$d"))")
done < <(lsblk -ndo PATH)

[[ ${#AVAILABLE_DISKS[@]} -eq 0 ]] && error "No disks found"

printf "Available disks:\n" >/dev/tty
DISK_SEL=$(select_opt "Select installation disk" "${AVAILABLE_DISKS[@]}")
DISK="${AVAILABLE_DISKS[$DISK_SEL]%% *}"
info "Selected disk: $DISK"

confirm "This will ERASE ALL DATA on $DISK. Continue?" || error "Installation aborted by user"

printf "\nHostname: "
read -r HOSTNAME
: "${HOSTNAME:=aero}"

printf "Username: "
read -r USERNAME
: "${USERNAME:=user}"

while true; do
    printf "User password: "
    read -rs USER_PASS
    printf "\n"
    printf "Confirm password: "
    read -rs USER_PASS2
    printf "\n"
    [[ "$USER_PASS" == "$USER_PASS2" && -n "$USER_PASS" ]] && break
    warn "Passwords do not match or are empty. Try again."
done

ROOT_PASS="$USER_PASS"

# ---------------------------------------------------------------------------
#  Phase 2 – Partitioning
# ---------------------------------------------------------------------------

info "Partitioning $DISK..."

if $UEFI; then
    parted -s "$DISK" mklabel gpt \
        mkpart primary fat32 1MiB 1025MiB \
        set 1 esp on \
        mkpart primary btrfs 1025MiB 100%
    sleep 1
    EFI_PART=$(get_partition "$DISK" 1)
    ROOT_PART=$(get_partition "$DISK" 2)
    mkfs.fat -F32 "$EFI_PART"
else
    parted -s "$DISK" mklabel msdos \
        mkpart primary ext4 1MiB 1025MiB \
        set 1 boot on \
        mkpart primary btrfs 1025MiB 100%
    sleep 1
    BOOT_PART=$(get_partition "$DISK" 1)
    ROOT_PART=$(get_partition "$DISK" 2)
    mkfs.ext4 "$BOOT_PART"
fi
ok

# ---------------------------------------------------------------------------
#  Phase 3 – Btrfs subvolumes
# ---------------------------------------------------------------------------

info "Creating Btrfs subvolumes..."
mkfs.btrfs -f "$ROOT_PART"
mount "$ROOT_PART" /mnt

btrfs subvolume create /mnt/@
btrfs subvolume create /mnt/@home
btrfs subvolume create /mnt/@cache
btrfs subvolume create /mnt/@log
btrfs subvolume create /mnt/@snapshots
ok

umount /mnt

# ---------------------------------------------------------------------------
#  Phase 4 – Mount subvolumes
# ---------------------------------------------------------------------------

info "Mounting subvolumes..."
mount -o compress=zstd,subvol=@ "$ROOT_PART" /mnt

mkdir -p /mnt/{home,var/cache,var/log,.snapshots}
mount -o compress=zstd,subvol=@home "$ROOT_PART" /mnt/home
mount -o compress=zstd,subvol=@cache "$ROOT_PART" /mnt/var/cache
mount -o compress=zstd,subvol=@log "$ROOT_PART" /mnt/var/log
mount -o compress=zstd,subvol=@snapshots "$ROOT_PART" /mnt/.snapshots

if $UEFI; then
    mkdir -p /mnt/boot
    mount "$EFI_PART" /mnt/boot
else
    mount "$BOOT_PART" /mnt/boot
fi
ok

# ---------------------------------------------------------------------------
#  Phase 5 – Pacstrap
# ---------------------------------------------------------------------------

info "Installing base system (this may take a while)..."
pacstrap /mnt base linux linux-firmware base-devel btrfs-progs snapper \
    hyprland hyprlock hypridle hyprpaper waybar uwsm \
    greetd greetd-tuigreet \
    ghostty \
    zsh zsh-autosuggestions zsh-syntax-highlighting zsh-completions \
    networkmanager iwd \
    pipewire wireplumber pipewire-pulse \
    xdg-desktop-portal-hyprland xdg-desktop-portal-gtk \
    polkit-gnome gnome-keyring \
    brightnessctl playerctl pamixer \
    grim slurp wl-clipboard swaybg \
    fzf ripgrep fd bat eza zoxide \
    sudo reflector pacman-contrib \
    starship btop lazygit tmux \
    git vim neovim nano go \
    noto-fonts noto-fonts-emoji ttf-jetbrains-mono-nerd \
    limine
ok

# ---------------------------------------------------------------------------
#  Phase 6 – Generate fstab
# ---------------------------------------------------------------------------

info "Generating fstab..."
genfstab -U /mnt >> /mnt/etc/fstab
ok

# ---------------------------------------------------------------------------
#  Phase 7 – Copy system files to installed system
# ---------------------------------------------------------------------------

info "Copying system configuration files..."

# Systemd services (copied from live environment before chroot)
mkdir -p /mnt/etc/systemd/system
cp /etc/systemd/system/aero-firstboot.service /mnt/etc/systemd/system/ 2>/dev/null || true
cp /etc/systemd/system/snapper-boot.service /mnt/etc/systemd/system/ 2>/dev/null || true

# Snapper configs (copied into chroot for post-create-config overlay)
mkdir -p /mnt/usr/share/aero/configs/snapper
cp "$AERO_CONFIGS/snapper/root" /mnt/usr/share/aero/configs/snapper/root
cp "$AERO_CONFIGS/snapper/home" /mnt/usr/share/aero/configs/snapper/home

# First-boot and hardware scripts
mkdir -p /mnt/usr/share/aero/scripts
cp "$AERO_SCRIPTS/first-boot.sh" /mnt/usr/share/aero/scripts/ 2>/dev/null || true
cp "$AERO_SCRIPTS/hardware-detect.sh" /mnt/usr/share/aero/scripts/ 2>/dev/null || true
ok

# ---------------------------------------------------------------------------
#  Phase 8 – Chroot configuration
# ---------------------------------------------------------------------------

info "Configuring system..."

arch-chroot /mnt /bin/bash <<CHROOT
set -euo pipefail

# Locale
echo "LOCALE=$LOCALE" >> /etc/locale.conf
echo "$LOCALE UTF-8" > /etc/locale.gen
locale-gen

# Timezone
ln -sf "/usr/share/zoneinfo/$TIMEZONE" /etc/localtime
hwclock --systohc

# Keymap
echo "KEYMAP=$KEYMAP" > /etc/vconsole.conf

# Hostname
echo "$HOSTNAME" > /etc/hostname
cat > /etc/hosts <<EOF
127.0.0.1   localhost
::1         localhost
127.0.1.1   $HOSTNAME.localdomain $HOSTNAME
EOF

# Root password
echo "root:$ROOT_PASS" | chpasswd

# User
useradd -mG wheel,audio,video,input,storage,network "$USERNAME"
echo "$USERNAME:$USER_PASS" | chpasswd
echo "$USERNAME ALL=(ALL) ALL" > /etc/sudoers.d/10-aero-user

# Shell
chsh -s /usr/bin/zsh "$USERNAME"

# Build yay from AUR (needed for future AUR packages)
if sudo -u "$USERNAME" git clone https://aur.archlinux.org/yay.git /tmp/yay; then
    cd /tmp/yay
    sudo -u "$USERNAME" makepkg -d --noconfirm || true
    pacman -U yay-*.pkg.tar.zst --noconfirm || true
    cd /
    rm -rf /tmp/yay
fi

# mkinitcpio – update hooks for btrfs
sed -i 's/^HOOKS=.*/HOOKS=(base udev autodetect microcode modconf kms keyboard keymap consolefont block encrypt btrfs filesystems fsck)/' /etc/mkinitcpio.conf
mkinitcpio -P

# greetd
cat > /etc/greetd/config.toml <<'GREETD'
[terminal]
vt = 1

[default_session]
command = "tuigreet --time --cmd start-hyprland --remember --remember-user-session --user-menu --issue \"Authenticate into aero\""
user = "greeter"

[initial_session]
command = "tuigreet --time --cmd start-hyprland --remember --remember-user-session --user-menu --issue \"Authenticate into aero\""
user = "greeter"
GREETD

cat > /etc/pam.d/greetd <<'PAM'
auth     required  pam_securetty.so
auth     requisite pam_nologin.so
auth     include   system-login
account  include   system-login
session  include   system-login
PAM

systemctl enable greetd
systemctl enable NetworkManager
systemctl enable pipewire pipewire-pulse wireplumber --global

# First-boot service (snapper-boot is enabled by first-boot.sh)
systemctl enable aero-firstboot

CHROOT
ok

# ---------------------------------------------------------------------------
#  Phase 9 – Install Limine
# ---------------------------------------------------------------------------

info "Installing Limine bootloader..."

if $UEFI; then
    mkdir -p /mnt/boot/EFI/BOOT
    cp /usr/share/limine/BOOTX64.EFI /mnt/boot/EFI/BOOT/BOOTX64.EFI
    cat > /mnt/boot/EFI/BOOT/limine.conf <<'LIMINE'
timeout: 5

entry "Aero Linux"
    protocol: linux
    kernel_path: boot():/vmlinuz-linux
    cmdline: root=UUID=ROOT_UUID rw rootflags=subvol=@ quiet loglevel=3
    module_path: boot():/initramfs-linux.img

entry "Aero Linux (fallback)"
    protocol: linux
    kernel_path: boot():/vmlinuz-linux
    cmdline: root=UUID=ROOT_UUID rw rootflags=subvol=@ quiet loglevel=3
    module_path: boot():/initramfs-linux-fallback.img

entry "Aero Linux (snapshot)"
    protocol: linux
    kernel_path: boot():/vmlinuz-linux
    cmdline: root=UUID=ROOT_UUID rw rootflags=subvol=@/.snapshots/X/snapshot quiet loglevel=3
    module_path: boot():/initramfs-linux.img

entry "Reboot"
    protocol: reboot

entry "Power Off"
    protocol: poweroff
LIMINE
    ROOT_UUID=$(blkid -s UUID -o value "$ROOT_PART")
    sed -i "s/ROOT_UUID/$ROOT_UUID/g" /mnt/boot/EFI/BOOT/limine.conf
else
    arch-chroot /mnt /bin/bash <<'CHROOT'
limine-install --bios /boot /dev/DISK
cat > /boot/limine.conf <<'LIMINE'
timeout: 5

entry "Aero Linux"
    protocol: linux
    kernel_path: /boot/vmlinuz-linux
    cmdline: root=UUID=ROOT_UUID rw rootflags=subvol=@ quiet loglevel=3
    module_path: /boot/initramfs-linux.img

entry "Aero Linux (fallback)"
    protocol: linux
    kernel_path: /boot/vmlinuz-linux
    cmdline: root=UUID=ROOT_UUID rw rootflags=subvol=@ quiet loglevel=3
    module_path: /boot/initramfs-linux-fallback.img

entry "Aero Linux (snapshot)"
    protocol: linux
    kernel_path: /boot/vmlinuz-linux
    cmdline: root=UUID=ROOT_UUID rw rootflags=subvol=@/.snapshots/X/snapshot quiet loglevel=3
    module_path: /boot/initramfs-linux.img

entry "Reboot"
    protocol: reboot

entry "Power Off"
    protocol: poweroff
LIMINE
CHROOT
    ROOT_UUID=$(blkid -s UUID -o value "$ROOT_PART")
    sed -i "s/ROOT_UUID/$ROOT_UUID/g" /mnt/boot/limine.conf
    sed -i "s|/dev/DISK|$DISK|g" /mnt/boot/limine.conf
fi
ok

# ---------------------------------------------------------------------------
#  Phase 10 – Copy desktop configurations
# ---------------------------------------------------------------------------

info "Copying desktop configurations..."
if [[ -d "$AERO_CONFIGS" ]]; then
    for dir in hypr waybar ghostty zsh mako wlogout walker; do
        [[ -d "$AERO_CONFIGS/$dir" ]] && cp -r "$AERO_CONFIGS/$dir" /mnt/home/"$USERNAME"/.config/
    done
    USER_UID=$(arch-chroot /mnt id -u "$USERNAME")
    USER_GID=$(arch-chroot /mnt id -g "$USERNAME")
    chown -R "$USER_UID":"$USER_GID" /mnt/home/"$USERNAME"/.config
fi
ok

# ---------------------------------------------------------------------------
#  Phase 11 – Finalize
# ---------------------------------------------------------------------------

# Write config for first-boot script
cat > /mnt/etc/aero-install.conf <<EOF
USERNAME=$USERNAME
HOSTNAME=$HOSTNAME
KEYMAP=$KEYMAP
LOCALE=$LOCALE
TIMEZONE=$TIMEZONE
UEFI=$UEFI
EOF

touch /mnt/etc/aero-installed

info "Installation complete!"
printf "\n"
printf "\033[1;32m  Aero Linux has been installed successfully.\033[0m\n"
printf "\n"
printf "  Disk:       %s\n" "$DISK"
printf "  Hostname:   %s\n" "$HOSTNAME"
printf "  Username:   %s\n" "$USERNAME"
printf "  Desktop:    Hyprland\n"
printf "\n"

if confirm "Reboot now?"; then
    info "Rebooting..."
    umount -R /mnt
    reboot
else
    info "You may reboot later with: sudo reboot"
fi
